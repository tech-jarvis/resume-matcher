# Anthropic (required for matcher, convert, updater) — https://console.anthropic.com/settings/keys
# App shows a clear error if this is missing, invalid, or out of credits.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App URL (used for redirects)
NEXT_PUBLIC_SITE_URL=https://resume-matcher-red-alpha.vercel.app

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SESSION_SECRET=generate-a-long-random-string-here
